DECLARE SUB BUMPREF(X%)
DECLARE SUB BUMPVAL(BYVAL X%)
DECLARE FUNCTION ADDREF%(X%)
DECLARE FUNCTION ADDVAL%(BYVAL X%)

DIM VALUE% AS INTEGER
VALUE% = 5

BUMPREF VALUE%
PRINT VALUE%

BUMPVAL VALUE%
PRINT VALUE%

PRINT ADDREF%(VALUE%)
PRINT VALUE%

PRINT ADDVAL%(VALUE%)
PRINT VALUE%

SUB BUMPREF(X%)
    X% = X% + 1
END SUB

SUB BUMPVAL(BYVAL X%)
    X% = X% + 1
END SUB

FUNCTION ADDREF%(X%)
    X% = X% + 2
    ADDREF% = X%
END FUNCTION

FUNCTION ADDVAL%(BYVAL X%)
    X% = X% + 3
    ADDVAL% = X%
END FUNCTION
