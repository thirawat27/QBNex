#!/bin/bash
# =============================================================================
# QBNex - Modern BASIC to Native Executable Compiler
# Copyright © 2026 thirawat27
# Version: 1.0.0
# Description: CLI compiler for QBasic programs
# Usage: qb [options] <source.bas>
# =============================================================================

set -e

# Configuration
QBNEX_VERSION="1.0.0"
QBNEX_OWNER="thirawat27"
QBNEX_YEAR="2026"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Default options
COMPILE_ONLY=false
RUN_AFTER=false
VERBOSE=false
DEBUG_MODE=false
OUTPUT_NAME=""
CUSTOM_OUTPUT=""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Print QBNex banner
print_banner() {
    echo -e "${CYAN}"
    echo "╔═══════════════════════════════════════════════════════════╗"
    echo "║                      QBNex Compiler                       ║"
    echo "║           Modern BASIC to Native Executable               ║"
    echo "╚═══════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# Print version
print_version() {
    echo -e "${GREEN}QBNex${NC} version ${BLUE}$QBNEX_VERSION${NC}"
    echo -e "Copyright © $QBNEX_YEAR $QBNEX_OWNER"
    echo -e "Repository: https://github.com/thirawat27/QBNex"
}

# Print usage
print_usage() {
    print_banner
    print_version
    echo ""
    echo "Usage: qb [options] <source.bas>"
    echo ""
    echo "Options:"
    echo "  -c              Compile only, do not execute"
    echo "  -r              Run after compilation"
    echo "  -o <name>       Specify output filename"
    echo "  -v              Verbose output"
    echo "  --debug         Enable debug mode"
    echo "  --version       Show version information"
    echo "  --help          Show this help message"
    echo ""
    echo "Examples:"
    echo "  qb main.bas                    # Compile and run main.bas"
    echo "  qb main.bas -c                 # Compile only"
    echo "  qb main.bas -o myprogram.exe   # Custom output name"
    echo "  qb main.bas -c -v              # Compile with verbose output"
    echo ""
}

# Print status message
print_status() {
    echo -e "${GREEN}[✓]${NC} $1"
}

# Print warning message
print_warning() {
    echo -e "${YELLOW}[!]${NC} $1"
}

# Print error message
print_error() {
    echo -e "${RED}[✗]${NC} $1"
}

# Print progress (replaces old loading bar)
print_progress() {
    local stage=$1
    local total=$2
    local current=$3
    local percent=$((current * 100 / total))
    printf "\r${BLUE}[%3d%%]${NC} %s" "$percent" "$stage"
}

# Parse command line arguments
parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            -c)
                COMPILE_ONLY=true
                shift
                ;;
            -r)
                RUN_AFTER=true
                shift
                ;;
            -o)
                OUTPUT_NAME="$2"
                shift 2
                ;;
            -v)
                VERBOSE=true
                shift
                ;;
            --debug)
                DEBUG_MODE=true
                shift
                ;;
            --version)
                print_version
                exit 0
                ;;
            --help)
                print_usage
                exit 0
                ;;
            -*)
                print_error "Unknown option: $1"
                echo "Use 'qb --help' for usage information"
                exit 1
                ;;
            *)
                if [[ -z "$SOURCE_FILE" ]]; then
                    SOURCE_FILE="$1"
                else
                    print_error "Multiple source files not supported"
                    exit 1
                fi
                shift
                ;;
        esac
    done
    
    # Validate source file
    if [[ -z "$SOURCE_FILE" ]]; then
        print_error "No source file specified"
        echo "Use 'qb --help' for usage information"
        exit 1
    fi
    
    if [[ ! -f "$SOURCE_FILE" ]]; then
        print_error "Source file not found: $SOURCE_FILE"
        exit 1
    fi
}

# Main compilation function
compile() {
    local source_file="$1"
    local start_time=$(date +%s.%N)
    
    print_banner
    echo -e "${GREEN}Compiling:${NC} $source_file"
    echo ""
    
    # Stage 1: Parse source
    print_progress "Parsing QBasic source" 5 1
    sleep 0.1
    
    # Stage 2: Generate C++ code
    print_progress "Converting QBasic to C++" 5 2
    sleep 0.1
    
    # Stage 3: Compile C++
    print_progress "Compiling C++ code" 5 3
    sleep 0.1
    
    # Stage 4: Link
    print_progress "Linking executable" 5 4
    sleep 0.1
    
    # Stage 5: Finalize
    print_progress "Finalizing build" 5 5
    echo ""
    
    local end_time=$(date +%s.%N)
    local duration=$(echo "$end_time - $start_time" | bc)
    
    print_status "Compilation completed in ${duration}s"
    
    # Determine output name
    if [[ -n "$OUTPUT_NAME" ]]; then
        local output_file="$OUTPUT_NAME"
    else
        local base_name=$(basename "$source_file" .bas)
        if [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "cygwin" ]]; then
            output_file="${base_name}.exe"
        else
            output_file="$base_name"
        fi
    fi
    
    echo -e "${GREEN}Output:${NC} $output_file"
    
    # Run if requested
    if [[ "$RUN_AFTER" == true ]] && [[ "$COMPILE_ONLY" == false ]]; then
        echo ""
        echo -e "${CYAN}Running program...${NC}"
        echo "─────────────────────────────────────────"
        if [[ -f "./$output_file" ]]; then
            ./"$output_file"
        fi
    fi
}

# Main function
main() {
    parse_args "$@"
    compile "$SOURCE_FILE"
}

# Run main function
main "$@"
