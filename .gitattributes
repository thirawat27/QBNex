# Auto detect text files and perform LF normalization
* text=auto

# Rust source files
*.rs text eol=lf

# TOML files
*.toml text eol=lf

# Markdown files
*.md text eol=lf

# QBasic files
*.bas text eol=crlf

# Binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.a binary
*.lib binary
*.pdb binary

# Archives
*.zip binary
*.tar binary
*.gz binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
